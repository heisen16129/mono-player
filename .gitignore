# Dependencies
node_modules/

# Frontend build output
dist/

# Rust build output
target/
src-tauri/target/
plugins/*/target/

# Tauri bundles and generated installers
src-tauri/bundle/
src-tauri/target/*/bundle/
src-tauri/gen/schemas/

# Logs
*.log
.vite-dev.err.log
.vite-dev.out.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment and local configuration
.env
.env.*
!.env.example

# Editor and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# Local history and uploaded scratch files
.history/
.uploads/
.agents/

# Temporary/debug artifacts
*.tmp
*.temp
*.pdb
*.sqlite
*.sqlite3
tmp_*

# Keep plugin wasm release artifacts available for distribution.
!plugins/*/dist/
!plugins/*/dist/*.wasm
